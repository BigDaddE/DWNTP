# DWNTP real-world benchmark environment template.
# Copy to realworld.env and fill in the values for your deployment.
#   cp realworld.env.example realworld.env
#   # then edit realworld.env
# run-realworld-benchmark.sh sources this file.

# Public IP or DNS name of the coordinator host.
# Hosts orderer.dwntp.com, peer0.org1.dwntp.com.
MAIN_PUBLIC_HOST=CHANGE_ME_COORDINATOR_PUBLIC_IP

# Public IP or DNS name of the remote host.
# Hosts peer1.org1.dwntp.com.
REMOTE_PUBLIC_HOST=CHANGE_ME_REMOTE_PUBLIC_IP

# Port on MAIN_PUBLIC_HOST that exposes orderer.dwntp.com:7050.
ORDERER_PORT=7050

# Port on MAIN_PUBLIC_HOST that exposes peer0.org1.dwntp.com:7051.
PEER0_PORT=7051

# Port on REMOTE_PUBLIC_HOST that exposes peer1.org1.dwntp.com:7051.
# Must match PEER_PORT in the remote host's deploy_peer1/node.env.
PEER1_PORT=7061

# Channel and chaincode identifiers. Match the values the coordinator was launched with.
CHANNEL=dwntpchannel
CONTRACT_ID=dwntp
